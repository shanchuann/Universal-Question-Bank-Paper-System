GHCR_OWNER=your-github-org-or-username
# IMPORTANT: GHCR owner must be lowercase
# Example: shanchuann

BACKEND_TAG=prod
FRONTEND_TAG=prod

# Optional: explicit path to Docker auth config used by Watchtower
DOCKER_CONFIG_PATH=/root/.docker/config.json

# Optional timezone shared by containers
TZ=Asia/Shanghai

DB_URL=jdbc:postgresql://127.0.0.1:5432/uqbank
DB_USERNAME=postgres
DB_PASSWORD=change-me

FLYWAY_ENABLED=true
JPA_DDL_AUTO=validate
SQL_INIT_MODE=never

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=example@qq.com
SMTP_PASS=change-me

# Production recommendation: disable built-in Ollama process unless deployed separately
AI_OLLAMA_ENABLED=false
AI_OLLAMA_BASE_URL=http://ollama:11434
AI_OLLAMA_MODEL=gemma4
AI_OLLAMA_TIMEOUT_MS=180000

# Production recommendation: avoid destructive legacy cleanup on every startup
APP_CLEANUP_DROP_LEGACY_QUESTION_OPTIONS=false
